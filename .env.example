# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coc_cassation?schema=public"

# Secret used to sign session JWTs (change in production, min 32 chars)
AUTH_SECRET="change-me-to-a-long-random-secret-string-min-32-chars"

# Optional: default seeded admin password (used by prisma/seed.ts)
SEED_ADMIN_PASSWORD="Admin@12345"
